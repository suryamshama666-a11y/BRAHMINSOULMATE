# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
# NOTE: SUPABASE_SERVICE_ROLE_KEY belongs in backend/.env only (not here!)

# Razorpay Configuration (Test Mode)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_test_secret_here

# SendGrid Configuration (Optional)
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=noreply@brahminsoulmate.com

# Twilio Configuration (Optional)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Application Configuration
VITE_APP_URL=http://localhost:5173
NODE_ENV=development

# Development Mode (ONLY FOR DEVELOPMENT!)
# Set to 'true' to bypass authentication during development
VITE_DEV_BYPASS_AUTH=false

# Feature Flags (Optional)
VITE_ENABLE_SMS=false
VITE_ENABLE_EMAIL=false
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_VIDEO_DATES=true

# Jitsi Configuration (Optional - uses public server by default)
VITE_JITSI_DOMAIN=meet.jit.si

# Analytics (Optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Advanced Horoscope API (VedicAstroAPI)
VEDIC_ASTRO_API_KEY=your_vedic_astro_api_key_here

# SECURITY WARNING: Never commit secrets to version control!
# This is an example file - create .env.local with your actual credentials
