# ===========================================
# BRAHMIN SOULMATE CONNECT - ENVIRONMENT CONFIGURATION
# ===========================================

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
NODE_ENV=development
VITE_APP_NAME=Brahmin Soulmate Connect
VITE_APP_VERSION=1.0.0
VITE_APP_URL=http://localhost:8080
VITE_API_BASE_URL=http://localhost:3001
# Backend CORS origin for dev should match Vite dev URL above
FRONTEND_URL=http://localhost:8080

# ===========================================
# DATABASE CONFIGURATION (SUPABASE)
# ===========================================
# These two are required for the frontend and scripts that talk directly to Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Backend-only secret (do not expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://user:password@localhost:5432/brahmin_soulmate

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
VITE_JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters
VITE_ENCRYPTION_KEY=your_encryption_key_32_characters
SESSION_SECRET=your_session_secret_32_characters
BCRYPT_ROUNDS=12

# ===========================================
# PAYMENT GATEWAY (RAZORPAY)
# ===========================================
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Subscription Plans (in paise)
BASIC_PLAN_PRICE=99900    # ₹999
PREMIUM_PLAN_PRICE=249900 # ₹2499
ELITE_PLAN_PRICE=499900   # ₹4999

# ===========================================
# EMAIL SERVICES
# ===========================================
# Gmail SMTP
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
VITE_FROM_EMAIL=noreply@brahminsoulmate.com

# SendGrid (Alternative)
VITE_SENDGRID_API_KEY=your_sendgrid_api_key

# Mailgun (Alternative)
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain

# ===========================================
# SMS & VOICE SERVICES (TWILIO)
# ===========================================
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
VITE_TWILIO_PHONE_NUMBER=+1234567890

# ===========================================
# PUSH NOTIFICATIONS (VAPID)
# ===========================================
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=your_email@example.com

# ===========================================
# FILE UPLOAD & STORAGE
# ===========================================
# Supabase Storage
SUPABASE_STORAGE_BUCKET=profile-images
MAX_FILE_SIZE=10485760  # 10MB

# Cloudinary (Alternative)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AWS S3 (Alternative)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=brahmin-soulmate-uploads

# ===========================================
# VIDEO CALLING SERVICES
# ===========================================
# Agora
VITE_AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Twilio Video (Alternative)
TWILIO_VIDEO_API_KEY=your_twilio_video_api_key
TWILIO_VIDEO_API_SECRET=your_twilio_video_api_secret

# ===========================================
# EXTERNAL APIS
# ===========================================
# Google Services
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Social Login
VITE_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
VITE_FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ===========================================
# ANALYTICS & MONITORING
# ===========================================
# Sentry (Error Tracking) - Frontend
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=1.0.0
# Sentry sourcemaps upload (CI/production only)
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug

# Google Analytics
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel (Alternative)
VITE_MIXPANEL_TOKEN=your_mixpanel_token

# Plausible Analytics (Alternative)
VITE_PLAUSIBLE_DOMAIN=brahminsoulmate.com

# ===========================================
# CACHING & PERFORMANCE
# ===========================================
# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Cache Settings
ENABLE_CACHING=true
CACHE_TTL=3600  # 1 hour

# ===========================================
# RATE LIMITING & SECURITY
# ===========================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:5173
HELMET_CSP_ENABLED=true
TRUST_PROXY=false

# ===========================================
# FEATURE FLAGS
# ===========================================
VITE_ENABLE_VIDEO_CALLS=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
VITE_ENABLE_SMS_NOTIFICATIONS=false
VITE_ENABLE_HOROSCOPE_MATCHING=true
VITE_ENABLE_PREMIUM_FEATURES=true
VITE_ENABLE_ADMIN_PANEL=true
VITE_ENABLE_COMMUNITY_FORUM=true
VITE_ENABLE_EVENTS=true
VITE_ENABLE_SUCCESS_STORIES=true

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
ADMIN_EMAIL=admin@brahminsoulmate.com
ADMIN_PASSWORD=secure_admin_password_change_this
ADMIN_PANEL_SECRET=your_admin_panel_secret

# ===========================================
# DEVELOPMENT & DEBUGGING
# ===========================================
VITE_DEBUG=true
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
ENABLE_SWAGGER_DOCS=true

# ===========================================
# MATCHING ALGORITHM CONFIGURATION
# ===========================================
MATCH_RADIUS_KM=50
MAX_MATCHES_PER_DAY=20
COMPATIBILITY_THRESHOLD=70

# ===========================================
# NOTIFICATION CONFIGURATION
# ===========================================
EMAIL_BATCH_SIZE=100
PUSH_NOTIFICATION_BATCH_SIZE=1000
NOTIFICATION_RETRY_ATTEMPTS=3

# ===========================================
# CONTENT MODERATION
# ===========================================
ENABLE_CONTENT_MODERATION=true
PROFANITY_FILTER_ENABLED=true
IMAGE_MODERATION_ENABLED=true

# ===========================================
# BACKUP & MAINTENANCE
# ===========================================
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently performing scheduled maintenance

# ===========================================
# PRODUCTION OVERRIDES (Uncomment for production)
# ===========================================
# NODE_ENV=production
# VITE_DEBUG=false
# VITE_APP_URL=https://brahminsoulmate.com
# VITE_API_BASE_URL=https://api.brahminsoulmate.com
# CORS_ORIGIN=https://brahminsoulmate.com
# COOKIE_SECURE=true
# TRUST_PROXY=true
# RATE_LIMIT_MAX_REQUESTS=50
# LOG_LEVEL=warn
# ENABLE_REQUEST_LOGGING=false

# ===========================================
# HEALTH CHECKS & MONITORING
# ===========================================
HEALTH_CHECK_INTERVAL=30000  # 30 seconds
ENABLE_METRICS=true
METRICS_PORT=9090

# ===========================================
# TESTING CONFIGURATION
# ===========================================
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/brahmin_soulmate_test
VITE_TEST_MODE=false