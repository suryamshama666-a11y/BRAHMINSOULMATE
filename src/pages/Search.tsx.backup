import { useState, useEffect } from 'react';
import Footer from '@/components/Footer';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import { Pagination } from '@/components/ui/pagination';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Input } from '@/components/ui/input';
import { useNavigate, Link } from 'react-router-dom';
import { 
  BarChart2, Grid, Map, Settings
} from 'lucide-react';
import { api } from '@/lib/api';
import { toast } from 'sonner';
import { useAdvancedSearch, SearchFilters } from '@/hooks/useAdvancedSearch';
import { useShortlist } from '@/hooks/useShortlist';
import { AdvancedSearchModal } from '@/components/search/AdvancedSearchModal';
import ProfileGrid from '@/components/search/ProfileGrid';
import { Skeleton } from '@/components/ui/skeleton';
import { Profile } from '@/types/profile';
import LocationSearch from '@/components/search/LocationSearch';
import MapView from '@/components/search/MapView';
import { ViewMode } from '@/components/search/ViewToggle';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import ProfileComparison from '@/components/search/ProfileComparison';

const Search = () => {
  const [searchTerm, setSearchTerm] = useState('');
  const [showAdvancedSearch, setShowAdvancedSearch] = useState(false);
  const [saveSearchName, setSaveSearchName] = useState('');
  const [sortBy] = useState<'relevance' | 'compatibility' | 'recent' | 'verified'>('compatibility');
  
  // Pagination state
  const [currentPage, setCurrentPage] = useState(1);
  const [profilesPerPage, setProfilesPerPage] = useState(9);
  const [totalPages, setTotalPages] = useState(1);
  
  // View mode state
  const [viewMode, setViewMode] = useState<ViewMode>('grid');
  const [activeTab, setActiveTab] = useState<'basic' | 'location'>('basic');
  
  // Comparison state
  const [selectedForComparison, setSelectedForComparison] = useState<string[]>([]);
  const [showComparison, setShowComparison] = useState(false);
  
  // Active filters state
  const [activeFilters, setActiveFilters] = useState<{
    label: string;
    value: string;
    type: string;
  }[]>([]);
  
  const {
    searchResults,
    performAdvancedSearch,
    saveSearch
  } = useAdvancedSearch();

  const { addToShortlist } = useShortlist();

  const [displayProfiles, setDisplayProfiles] = useState<any[]>([]);
  const [filteredProfiles, setFilteredProfiles] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  
  // Fallback profiles data
  const fallbackProfiles = [
    {
      id: '1',
      name: 'Priya Sharma',
      age: 28,
      location: { city: 'Mumbai', state: 'Maharashtra' },
      employment: { profession: 'Software Engineer' },
      education: 'B.Tech Computer Science',
      isVerified: true,
      compatibility_score: 95,
      last_active: new Date().toISOString(),
      photos: ['/api/placeholder/300/400']
    },
    {
      id: '2', 
      name: 'Anita Patel',
      age: 26,
      location: { city: 'Ahmedabad', state: 'Gujarat' },
      employment: { profession: 'Doctor' },
      education: 'MBBS',
      isVerified: true,
      compatibility_score: 92,
      last_active: new Date().toISOString(),
      photos: ['/api/placeholder/300/400']
    },
    {
      id: '3',
      name: 'Kavya Iyer',
      age: 25,
      location: { city: 'Chennai', state: 'Tamil Nadu' },
      employment: { profession: 'Teacher' },
      education: 'M.Ed',
      isVerified: false,
      compatibility_score: 88,
      last_active: new Date().toISOString(),
      photos: ['/api/placeholder/300/400']
    }
  ];

  // Load profiles from API
  useEffect(() => {
    const loadProfiles = async () => {
      try {
        setLoading(true);
        const result = await api.getProfiles({ page: 1, limit: 50 });
        const profiles = Array.isArray(result) ? result : result.data || [];
        
        // Use API data if available, otherwise use fallback profiles
        const profilesToUse = profiles.length > 0 ? profiles : fallbackProfiles;
        setFilteredProfiles(profilesToUse);
        setDisplayProfiles(profilesToUse);
      } catch (error) {
        console.error('Error loading profiles:', error);
        // Use fallback profiles when API fails
        setFilteredProfiles(fallbackProfiles);
        setDisplayProfiles(fallbackProfiles);
      } finally {
        setLoading(false);
      }
    };

    loadProfiles();
  }, []);

  // Update filtered profiles when search results change
  useEffect(() => {
    if (searchResults.length > 0) {
      setFilteredProfiles(searchResults);
    } else if (searchTerm === '') {
      // Keep the original loaded profiles
    }

    // Reset to first page when search results change
    setCurrentPage(1);
  }, [searchResults, searchTerm]);

  // Update display profiles based on pagination
  useEffect(() => {
    const sortedProfiles = sortProfiles(filteredProfiles);
    const indexOfLastProfile = currentPage * profilesPerPage;
    const indexOfFirstProfile = indexOfLastProfile - profilesPerPage;
    setDisplayProfiles(sortedProfiles.slice(indexOfFirstProfile, indexOfLastProfile));
    setTotalPages(Math.ceil(sortedProfiles.length / profilesPerPage));
  }, [filteredProfiles, currentPage, profilesPerPage, sortBy]);

  const handleBasicSearch = () => {
    if (!searchTerm.trim()) {
      setFilteredProfiles(fallbackProfiles);
      setActiveFilters([]);
      return;
    }

    const filtered = fallbackProfiles.filter(profile => {
      const searchTermMatch =
        profile.name?.toLowerCase().includes(searchTerm.toLowerCase()) ||
        profile.location?.city?.toLowerCase().includes(searchTerm.toLowerCase()) ||
        profile.employment?.profession?.toLowerCase().includes(searchTerm.toLowerCase());
      return searchTermMatch;
    });
    
    setFilteredProfiles(filtered);
    setActiveFilters([{
      label: 'Search',
      value: searchTerm,
      type: 'search'
    }]);
  };

  const handleSaveSearch = () => {
    if (!saveSearchName.trim()) {
      toast.error('Please enter a name for your search');
      return;
    }

    // Create search filters object with current search criteria
    const currentFilters: SearchFilters = {
      ageRange: [18, 50], // Default age range
      heightRange: [150, 200], // Default height range
      // Add other current filter values as needed
    };

    // Save the search
    saveSearch(saveSearchName.trim(), currentFilters);
    
    toast.success(`Search "${saveSearchName.trim()}" saved successfully`, {
      description: "You can access it from your saved searches",
      duration: 3000,
    });

    // Clear the save search input
    setSaveSearchName('');
  };

  const handleAdvancedSearch = (filters: SearchFilters) => {
    performAdvancedSearch(filters);
    
    // Create active filters from the search criteria
    const newActiveFilters = [];
    
    if (filters.ageRange) {
      newActiveFilters.push({
        label: 'Age',
        value: `${filters.ageRange[0]}-${filters.ageRange[1]} years`,
        type: 'age'
      });
    }
    
    if (filters.heightRange) {
      newActiveFilters.push({
        label: 'Height',
        value: `${filters.heightRange[0]}-${filters.heightRange[1]} cm`,
        type: 'height'
      });
    }
    
    if (filters.religion) {
      newActiveFilters.push({
        label: 'Religion',
        value: filters.religion,
        type: 'religion'
      });
    }
    
    if (filters.maritalStatus && filters.maritalStatus.length > 0) {
      newActiveFilters.push({
        label: 'Marital Status',
        value: filters.maritalStatus.join(', '),
        type: 'marital'
      });
    }
    
    if (filters.verified) {
      newActiveFilters.push({
        label: 'Verified',
        value: 'Yes',
        type: 'verified'
      });
    }
    
    setActiveFilters(newActiveFilters);
  };

  const handleLocationSearch = (params: { location: string; distance: number; useCurrentLocation: boolean }) => {
    // In a real implementation, this would filter profiles based on location and distance
    // For this demo, we'll just filter profiles that contain the location string in their city
    
    if (!params.location) {
      setFilteredProfiles(fallbackProfiles);
      setActiveFilters([]);
      return;
    }
    
    const filtered = fallbackProfiles.filter(profile => {
      return profile.location?.city?.toLowerCase().includes(params.location.toLowerCase());
    });
    
    setFilteredProfiles(filtered);
    setActiveFilters([
      {
        label: 'Location',
        value: params.location,
        type: 'location'
      },
      {
        label: 'Distance',
        value: `${params.distance} km`,
        type: 'distance'
      }
    ]);
    
    // Switch to map view when doing a location search
    setViewMode('map');
  };

  const handleSendInterest = (profileName: string, profileId: string) => {
    toast.success(`Interest sent to ${profileName}`, {
      description: "They will be notified of your interest",
      action: {
        label: "Undo",
        onClick: () => toast.error(`Interest to ${profileName} withdrawn`)
      }
    });
  };

  const handleShortlist = async (profileId: string, profileName: string) => {
    const result = await addToShortlist(profileId);
    if (result?.success) {
      toast.success(`Added to Favorites`, {
        description: `${profileName} has been added to your favorites list`,
        action: {
          label: "View Favorites",
          onClick: () => navigate('/favorites')
        }
      });
    }
  };
  
  const handleMessage = (profileId: string) => {
    const profile = displayProfiles.find(p => p.id === profileId);
    if (profile) {
      toast.success(`Opening chat with ${profile.name}`, {
        description: "You can now start a conversation"
      });
    }
  };

  const sortProfiles = (profiles: any[]) => {
    switch (sortBy) {
      case 'compatibility':
        return [...profiles].sort((a, b) => (b.compatibility_score || 0) - (a.compatibility_score || 0));
      case 'recent':
        return [...profiles].sort((a, b) => new Date(b.last_active || 0).getTime() - new Date(a.last_active || 0).getTime());
      case 'verified':
        return [...profiles].sort((a, b) => (b.isVerified ? 1 : 0) - (a.isVerified ? 1 : 0));
      default:
        return profiles;
    }
  };

  const handlePageChange = (page: number) => {
    setCurrentPage(page);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };
  
  const handleRemoveFilter = (filterType: string) => {
    setActiveFilters(prev => prev.filter(filter => filter.type !== filterType));
    
    // If removing the search filter, reset the search term
    if (filterType === 'search') {
      setSearchTerm('');
      setFilteredProfiles(fallbackProfiles);
    }
    
    // If removing location or distance filter, reset both
    if (filterType === 'location' || filterType === 'distance') {
      setActiveFilters(prev => prev.filter(filter => filter.type !== 'location' && filter.type !== 'distance'));
      setFilteredProfiles(fallbackProfiles);
    }
  };
  
  const handleClearAllFilters = () => {
    setActiveFilters([]);
    setSearchTerm('');
    setFilteredProfiles(fallbackProfiles);
  };

  const handleProfileSelect = (profileId: string) => {
    // In a real implementation, this could show a profile preview or navigate to the profile page
    toast.success(`Selected profile: ${profileId}`);
  };

  const handleCompareToggle = (profileId: string) => {
    setSelectedForComparison(prev => {
      // If already selected, remove it
      if (prev.includes(profileId)) {
        return prev.filter(id => id !== profileId);
      }
      
      // If not selected and we have less than 3 profiles, add it
      if (prev.length < 3) {
        return [...prev, profileId];
      }
      
      // If we already have 3 profiles, show a toast and don't add
      toast.error("You can compare up to 3 profiles at a time");
      return prev;
    });
  };

  const getProfilesForComparison = (): Profile[] => {
    return selectedForComparison
      .map(id => filteredProfiles.find(profile => profile.id === id))
      .filter(profile => profile !== undefined) as Profile[];
  };

  const navigate = useNavigate();

  return (
    <div className="min-h-screen bg-orange-50/30 pb-12">
      <div className="container mx-auto px-4 pt-6">
        {/* Navigation Header - WCAG 2.0 AA Compliant */}
        <div className="mb-6">
          <nav 
            className="flex items-center justify-center space-x-1 mb-6 flex-wrap"
            role="navigation"
            aria-label="Main navigation"
          >
            <Link to="/dashboard">
              <Button
                variant="ghost"
                className="px-4 py-2 text-gray-700 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                aria-label="Go to Home page"
              >
                Home
              </Button>
            </Link>
            <Link to="/dashboard">
              <Button
                variant="ghost"
                className="px-4 py-2 text-gray-700 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                aria-label="Go to Dashboard"
              >
                Dashboard
              </Button>
            </Link>
            <Button
              variant="ghost"
              className="px-4 py-2 bg-red-600 text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
              aria-current="page"
              aria-label="Search profiles - current page"
            >
              Search
            </Button>
            <Link to="/matches">
              <Button
                variant="ghost"
                className="px-4 py-2 text-gray-700 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                aria-label="View your matches"
              >
                Matches
              </Button>
            </Link>
            <Link to="/messages">
              <Button
                variant="ghost"
                className="px-4 py-2 text-gray-700 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                aria-label="View your messages"
              >
                Messages
              </Button>
            </Link>
            <Link to="/profile">
              <Button
                variant="ghost"
                className="px-4 py-2 text-gray-700 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                aria-label="View your profile"
              >
                Profile
              </Button>
            </Link>
            <Link to="/v-dates">
              <Button
                variant="ghost"
                className="px-4 py-2 text-gray-700 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                aria-label="Video dates"
              >
                V-Dates
              </Button>
            </Link>
            <Link to="/community">
              <Button
                variant="ghost"
                className="px-4 py-2 text-gray-700 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                aria-label="Community features"
              >
                Community
              </Button>
            </Link>
            <Link to="/events">
              <Button
                variant="ghost"
                className="px-4 py-2 text-gray-700 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                aria-label="View events"
              >
                Events
              </Button>
            </Link>
            <Link to="/help">
              <Button
                variant="ghost"
                className="px-4 py-2 text-gray-700 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                aria-label="Get help and support"
              >
                Help
              </Button>
            </Link>
          </nav>
        </div>

        {/* Header Section - WCAG 2.0 AA Compliant */}
        <header className="mb-8 text-center">
          <h1 className="text-4xl font-bold text-gray-900 mb-2">Search Profiles</h1>
          <p className="text-gray-700 text-lg">Find your perfect life partner with advanced matching.</p>
        </header>

        {/* Search Section - WCAG 2.0 AA Compliant */}
        <section className="bg-white rounded-lg shadow-sm border mb-8 p-8" aria-labelledby="search-heading">
          <h2 id="search-heading" className="sr-only">Search for profiles</h2>
          <Tabs 
            value={activeTab} 
            onValueChange={(value) => setActiveTab(value as 'basic' | 'location')}
            className="w-full"
          >
            <TabsList 
              className="grid w-full max-w-md mx-auto grid-cols-2 mb-6"
              role="tablist"
              aria-label="Search type selection"
            >
              <TabsTrigger 
                value="basic" 
                className="data-[state=active]:bg-red-600 data-[state=active]:text-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2"
                role="tab"
                aria-selected={activeTab === 'basic'}
                aria-controls="basic-search-panel"
              >
                Basic Search
              </TabsTrigger>
              <TabsTrigger 
                value="location" 
                className="data-[state=active]:bg-red-600 data-[state=active]:text-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2"
                role="tab"
                aria-selected={activeTab === 'location'}
                aria-controls="location-search-panel"
              >
                Location Search
              </TabsTrigger>
            </TabsList>
            
            <TabsContent 
              value="basic" 
              className="space-y-4"
              role="tabpanel"
              id="basic-search-panel"
              aria-labelledby="basic-search-tab"
            >
              <form 
                className="flex gap-4 max-w-4xl mx-auto"
                onSubmit={(e) => {
                  e.preventDefault();
                  handleBasicSearch();
                }}
                role="search"
                aria-label="Basic profile search"
              >
                <div className="flex-1">
                  <label htmlFor="search-input" className="sr-only">
                    Search profiles by name, location, or profession
                  </label>
                  <Input
                    id="search-input"
                    type="text"
                    placeholder="Search by name, location, or profession..."
                    value={searchTerm}
                    onChange={(e) => setSearchTerm(e.target.value)}
                    className="h-12 text-base border-gray-300 focus:border-red-500 focus:ring-red-500"
                    aria-describedby="search-help"
                  />
                  <div id="search-help" className="sr-only">
                    Enter keywords to search for profiles matching your criteria
                  </div>
                </div>
                <Button
                  type="submit"
                  className="h-12 px-8 bg-red-600 hover:bg-red-700 text-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                  aria-label="Start search"
                >
                  Search
                </Button>
                <Button
                  type="button"
                  variant="outline"
                  onClick={() => setShowAdvancedSearch(true)}
                  className="h-12 px-6 border-red-600 text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors"
                  aria-label="Open advanced search options"
                >
                  <Settings className="h-4 w-4 mr-2" aria-hidden="true" />
                  Advanced
                </Button>
              </form>
              
              {/* Save Search Section */}
              <div className="flex gap-4 max-w-4xl mx-auto mt-4">
                <div className="flex-1">
                  <label htmlFor="save-search-input" className="sr-only">
                    Save search name
                  </label>
                  <Input
                    id="save-search-input"
                    type="text"
                    placeholder="Save search as..."
                    value={saveSearchName}
                    onChange={(e) => setSaveSearchName(e.target.value)}
                    className="h-12 text-base border-gray-300 focus:border-red-500 focus:ring-red-500"
                    aria-describedby="save-search-help"
                  />
                  <div id="save-search-help" className="sr-only">
                    Enter a name to save your current search criteria
                  </div>
                </div>
                <Button
                  type="button"
                  onClick={handleSaveSearch}
                  disabled={!saveSearchName.trim()}
                  className="h-12 px-6 bg-orange-500 hover:bg-orange-600 text-white focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap"
                  aria-label="Save current search"
                >
                  Save Search
                </Button>
              </div>
              </form>
            </TabsContent>
            
            <TabsContent 
              value="location"
              role="tabpanel"
              id="location-search-panel"
              aria-labelledby="location-search-tab"
            >
              <LocationSearch onSearch={handleLocationSearch} />
            </TabsContent>
          </Tabs>
        </section>

        {/* Active filters display */}
        {activeFilters.length > 0 && (
          <div className="flex flex-wrap gap-2 mb-4">
            {activeFilters.map((filter, index) => (
              <Badge 
                key={index} 
                variant="outline" 
                className="px-3 py-1 bg-red-50 text-red-700 border-red-200 flex items-center gap-1"
              >
                <span className="font-medium">{filter.label}:</span> {filter.value}
                <button 
                  className="ml-1 hover:bg-red-100 rounded-full p-0.5"
                  onClick={() => handleRemoveFilter(filter.type)}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                </button>
              </Badge>
            ))}
            <Button 
              variant="ghost" 
              size="sm" 
              className="text-red-600 hover:text-red-800 hover:bg-red-50 text-xs"
              onClick={handleClearAllFilters}
            >
              Clear all
            </Button>
          </div>
        )}

        {/* Comparison section */}
        {selectedForComparison.length > 0 && (
          <div className="mb-4 flex justify-between items-center bg-amber-50 p-3 rounded-md border border-amber-200">
            <div className="flex items-center">
              <BarChart2 className="h-5 w-5 text-amber-600 mr-2" />
              <span className="font-medium">
                {selectedForComparison.length} {selectedForComparison.length === 1 ? 'profile' : 'profiles'} selected for comparison
              </span>
            </div>
            <div className="flex gap-2">
              <Button 
                variant="outline" 
                size="sm"
                onClick={() => setSelectedForComparison([])}
                className="text-xs border-amber-300 text-amber-700"
              >
                Clear Selection
              </Button>
              <Button 
                size="sm"
                onClick={() => setShowComparison(true)}
                className="text-xs bg-primary text-white"
              >
                Compare Profiles
              </Button>
            </div>
          </div>
        )}

        {/* Results Header - WCAG 2.0 AA Compliant */}
        <div className="mb-6 flex justify-between items-center">
          <div className="flex items-center gap-2">
            <p className="text-gray-800 font-medium" role="status" aria-live="polite">
              {loading ? 'Searching...' : `Showing ${filteredProfiles.length} profiles`}
            </p>
          </div>
          
          <div className="flex items-center gap-4">
            {/* View Toggle */}
            <div className="flex bg-white border rounded-lg p-1">
              <Button
                variant={viewMode === 'grid' ? 'default' : 'ghost'}
                size="sm"
                onClick={() => setViewMode('grid')}
                className={`${viewMode === 'grid' ? 'bg-red-500 text-white' : 'text-gray-600'}`}
              >
                <Grid className="h-4 w-4 mr-1" />
                Grid
              </Button>
              <Button
                variant={viewMode === 'map' ? 'default' : 'ghost'}
                size="sm"
                onClick={() => setViewMode('map')}
                className={`${viewMode === 'map' ? 'bg-red-500 text-white' : 'text-gray-600'}`}
              >
                <Map className="h-4 w-4 mr-1" />
                Map
              </Button>
            </div>
            
            <div className="flex items-center gap-2">
              <span className="text-sm text-gray-500">Profiles per page:</span>
              <Select 
                value={profilesPerPage.toString()} 
                onValueChange={(value) => setProfilesPerPage(parseInt(value))}
              >
                <SelectTrigger className="w-16 h-8">
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="6">6</SelectItem>
                  <SelectItem value="9">9</SelectItem>
                  <SelectItem value="12">12</SelectItem>
                  <SelectItem value="15">15</SelectItem>
                </SelectContent>
              </Select>
            </div>
          </div>
        </div>

        {loading ? (
          // Loading skeleton
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 my-6">
            {Array(profilesPerPage).fill(0).map((_, index) => (
              <div key={index} className="flex gap-4 p-4 border rounded-lg shadow-sm bg-white">
                <Skeleton className="w-20 h-24 rounded-md" />
                <div className="flex-1">
                  <Skeleton className="h-5 w-3/4 mb-2" />
                  <Skeleton className="h-4 w-1/2 mb-1" />
                  <Skeleton className="h-4 w-2/3 mb-1" />
                  <Skeleton className="h-4 w-3/4 mb-3" />
                  <div className="flex gap-2">
                    <Skeleton className="h-8 w-16 rounded-full" />
                    <Skeleton className="h-8 w-20 rounded-full" />
                    <Skeleton className="h-8 w-16 ml-auto rounded-full" />
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <>
            {viewMode === 'grid' ? (
              // Grid view
              <>
                <ProfileGrid 
                  profiles={displayProfiles} 
                  onSendInterest={(profileName, id) => {
                    handleSendInterest(profileName, id);
                  }}
                  onMessage={handleMessage}
                  onShortlist={handleShortlist}
                  onCompareToggle={handleCompareToggle}
                  selectedForComparison={selectedForComparison}
                />
                
                {/* Pagination for grid view */}
                {totalPages > 1 && (
                  <div className="flex justify-center mt-8">
                    <Pagination
                      currentPage={currentPage}
                      totalPages={totalPages}
                      onPageChange={handlePageChange}
                    />
                  </div>
                )}
              </>
            ) : (
              // Map view
              <MapView 
                profiles={filteredProfiles}
                onProfileSelect={handleProfileSelect}
                className="mb-6"
              />
            )}
            
            {/* No results message */}
            {filteredProfiles.length === 0 && !loading && (
              <div className="text-center py-20 bg-white rounded-lg shadow-sm border">
                <div className="mx-auto w-24 h-24 mb-6">
                  <svg viewBox="0 0 100 100" className="w-full h-full text-gray-300">
                    <circle cx="50" cy="50" r="45" fill="none" stroke="currentColor" strokeWidth="2"/>
                    <path d="M35 45 L45 55 L65 35" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"/>
                  </svg>
                </div>
                <h3 className="text-2xl font-bold text-gray-800 mb-2">No Profiles Found</h3>
                <p className="text-gray-500 mb-6 max-w-md mx-auto">
                  We couldn't find any profiles matching your search criteria. Try adjusting your filters or search terms.
                </p>
                <Button 
                  onClick={handleClearAllFilters}
                  className="bg-red-500 hover:bg-red-600 text-white px-8 py-3"
                >
                  Clear all filters
                </Button>
              </div>
            )}
          </>
        )}

        {/* Profile comparison modal */}
        {showComparison && (
          <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
            <div className="bg-white rounded-lg shadow-lg w-full max-w-6xl max-h-[90vh] overflow-y-auto">
              <ProfileComparison 
                profiles={getProfilesForComparison()}
                onClose={() => setShowComparison(false)}
                onRemoveProfile={(profileId) => {
                  setSelectedForComparison(prev => prev.filter(id => id !== profileId));
                }}
              />
            </div>
          </div>
        )}

        <AdvancedSearchModal
          open={showAdvancedSearch}
          onOpenChange={setShowAdvancedSearch}
          onSearch={handleAdvancedSearch}
          onSaveSearch={(name, filters) => {
            saveSearch(name, filters);
            toast.success(`Search "${name}" saved successfully`);
          }}
        />
      </div>
      <Footer />
    </div>
  );
};

export default Search;
